# ─────────────────────────────────────────────────────────────
# graymar-server 환경 변수 (템플릿)
# 실제 값은 .env 로 복사해 수정하세요.
# 기본값이 있는 항목은 주석 처리(선택).
# ─────────────────────────────────────────────────────────────

# ═══ Server ═══
# PORT=3000
# NODE_ENV=development
# CORS_ORIGINS=https://dimtale.com,https://www.dimtale.com,http://localhost:3001

# ═══ Database ═══
DATABASE_URL=postgresql://user:password@localhost:5432/textRpg

# ═══ Auth ═══
# 프로덕션에서는 반드시 긴 랜덤 값으로 교체 (32+ 바이트 권장)
JWT_SECRET=change-me-to-random-32-bytes-min

# ═══ LLM Core (공통 파라미터) ═══
# Provider: openai | claude | gemini | mock
LLM_PROVIDER=openai
LLM_MAX_RETRIES=2
LLM_TIMEOUT_MS=10000
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.8

# ═══ LLM OpenAI / OpenRouter ═══
# OpenRouter 경유 시 OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# 메인 서술 모델 (현 기본: Gemini 2.5 Flash)
OPENAI_MODEL=google/gemini-2.5-flash
# 교차 모델 (모델 차이로 다양성 확보 — 없으면 메인 동일)
LLM_ALTERNATE_MODEL=google/gemini-2.5-flash

# ═══ LLM Claude (선택) ═══
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ═══ LLM Gemini (선택) ═══
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 0 = thinking 비활성화 (비용 절감)
GEMINI_REASONING_MAX_TOKENS=0

# ═══ LLM Fallback (메인 실패 시) ═══
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=openai/gpt-4.1-mini

# ═══ LLM Light / Nano (경량 태스크용 — NanoDirector/Intent/FactExtract) ═══
# LIGHT_PROVIDER 미지정 시 LLM_PROVIDER 사용
LLM_LIGHT_PROVIDER=openai
LLM_LIGHT_MODEL=openai/gpt-4.1-nano
LLM_LIGHT_TIMEOUT_MS=6000

# ═══ LLM Advanced Features ═══
# JSON 구조화 출력 (스트리밍과 비호환, false 권장)
LLM_JSON_MODE=false
# 2-Stage 대사 분리 파이프라인
LLM_DIALOGUE_SPLIT=true
# 대사 전용 모델 (미지정 시 ALTERNATE/LIGHT 폴백)
LLM_DIALOGUE_MODEL=
# 스트림 분류기 (문장 단위 버퍼링)
LLM_STREAM_CLASSIFIER=true

# ═══ LLM Intent Parser v2 (Rule + LLM 하이브리드) ═══
# false = Rule 만 사용
INTENT_LLM_ENABLED=true
INTENT_LLM_PROVIDER=openai
INTENT_LLM_MODEL=openai/gpt-4.1-nano

# ═══ Slack (작업 알림, 선택) ═══
SLACK_WEBHOOK_URL=
